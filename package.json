{
  "name": "rslint-monorepo",
  "version": "0.2.0",
  "private": true,
  "description": "Rslint Monorepo",
  "homepage": "https://github.com/web-infra-dev/rslint#readme",
  "bugs": {
    "url": "https://github.com/web-infra-dev/rslint/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/web-infra-dev/rslint.git"
  },
  "license": "MIT",
  "scripts": {
    "build": "pnpm -r --filter=!@typescript/api --filter=!@typescript/ast --filter='@rslint/test-tools...' --filter='rslint...' build",
    "build:npm": "zx scripts/build-npm.mjs",
    "build:website": "pnpm --filter=!@typescript/api --filter=!@typescript/ast --filter=!@rslint/core --filter @rslint/website... -r build",
    "check-spell": "pnpx cspell lint --no-progress --show-context",
    "version": "zx scripts/version.mjs",
    "release": "pnpm publish -r --no-git-checks",
    "publish:vsce": "zx scripts/publish-marketplace.mjs",
    "publish:ovsx": "zx scripts/publish-marketplace.mjs --marketplace=ovsx",
    "format": "prettier --ignore-path=.prettierignore --config=.prettierrc.json --write .",
    "format:check": "prettier --ignore-path=.prettierignore --config=.prettierrc.json --check .",
    "test": "pnpm -r --filter=!@typescript/api --filter=!@typescript/ast --filter='@rslint/test-tools...' --filter='rslint...' test",
    "test:go": "go test ./internal/...",
    "typecheck": "pnpm tsgo -b tsconfig.json",
    "lint": "rslint",
    "lint:go": "golangci-lint run ./cmd/... ./internal/...",
    "format:go": "golangci-lint fmt ./cmd/... ./internal/...",
    "parity:ts-eslint": "bash scripts/refresh-ts-eslint-parity-artifacts.sh",
    "parity:ts-eslint:check": "python3 scripts/check_ts_eslint_parity_artifacts.py",
    "parity:ts-eslint:check:all": "bash scripts/check_ts_eslint_parity_all.sh",
    "parity:ts-eslint:check:strict": "bash scripts/check_ts_eslint_parity_all.sh && python3 scripts/generate_ts_eslint_parity_doctor.py --fail-on-critical",
    "parity:ts-eslint:check:tooling": "python3 scripts/check_ts_eslint_parity_tooling_sync.py",
    "parity:ts-eslint:commands": "python3 scripts/generate_ts_eslint_parity_commands.py",
    "parity:ts-eslint:diff": "python3 scripts/compare_ts_eslint_parity_trackers.py",
    "parity:ts-eslint:tasklist": "python3 scripts/generate_ts_eslint_parity_issue_tasklist.py",
    "parity:ts-eslint:tasklist:all": "bash scripts/generate_ts_eslint_parity_tasklists_all.sh",
    "parity:ts-eslint:issue-body": "python3 scripts/generate_ts_eslint_parity_issue_body.py",
    "parity:ts-eslint:issue-body:all": "bash scripts/generate_ts_eslint_parity_issue_bodies_all.sh",
    "parity:ts-eslint:rebuild-metadata": "bash scripts/rebuild_ts_eslint_parity_from_metadata.sh",
    "parity:ts-eslint:manifest": "python3 scripts/generate_ts_eslint_parity_manifest.py",
    "parity:ts-eslint:badges": "python3 scripts/generate_ts_eslint_parity_badges.py",
    "parity:ts-eslint:status": "python3 scripts/generate_ts_eslint_parity_status.py",
    "parity:ts-eslint:ci-summary": "python3 scripts/generate_ts_eslint_parity_ci_summary.py",
    "parity:ts-eslint:doctor": "python3 scripts/generate_ts_eslint_parity_doctor.py",
    "parity:ts-eslint:doctor:markdown": "python3 scripts/generate_ts_eslint_parity_doctor.py --markdown",
    "parity:ts-eslint:doctor:json": "python3 scripts/generate_ts_eslint_parity_doctor.py --json",
    "parity:ts-eslint:doctor:strict": "python3 scripts/generate_ts_eslint_parity_doctor.py --fail-on-critical",
    "parity:ts-eslint:top": "python3 scripts/generate_ts_eslint_parity_top.py",
    "parity:ts-eslint:verify-clean": "bash scripts/verify_ts_eslint_parity_clean.sh",
    "prepare": "husky",
    "migrate:tests": "sg scan -r ast-grep-rule.yml ./packages/rslint-test-tools/tests/typescript-eslint/rules/**/*.test.ts --update-all"
  },
  "devDependencies": {
    "@rslint/core": "workspace:*",
    "@rstest/core": "^0.7.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.6",
    "prettier": "3.7.4",
    "typescript": "5.9.3",
    "zx": "8.8.5",
    "@typescript/native-preview": "7.0.0-dev.20250904.1"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "prettier --write"
    ],
    "*.{json,css,scss,md,yaml,yml}": [
      "prettier --write"
    ]
  },
  "packageManager": "pnpm@10.13.1",
  "engines": {
    "pnpm": ">=10"
  },
  "files": [],
  "dependencies": {
    "@types/react": "^19.1.9"
  }
}
